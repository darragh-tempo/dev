{
  "redirects": [
    {
      "source": "/performance",
      "destination": "/performance/",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/performance/",
      "destination": "https://tempo-performance.vercel.app/"
    },
    {
      "source": "/performance/:path*",
      "destination": "https://tempo-performance.vercel.app/:path*"
    }
  ]
}
